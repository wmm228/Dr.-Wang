{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wmumu-home",
  "compatibility_date": "2026-05-13",
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    {
      "pattern": "drwang.wmumu.uno",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist"
  },
  "build": {
    "command": "node scripts/build-pages.mjs"
  }
}
